# Production backend for Baggins & Allies (API only)
FROM python:3.12-slim

WORKDIR /app

# Install deps
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# App code
COPY backend ./backend

# Run from project root so backend.api.main is resolvable
ENV PYTHONPATH=/app
ENV PORT=8000
EXPOSE 8000
# Use PORT so Railway/Render can inject it
CMD uvicorn backend.api.main:app --host 0.0.0.0 --port ${PORT}
