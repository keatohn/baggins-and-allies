# Copy to .env.production and set before: npm run build
# API base URL with NO trailing slash.
#
# Railway (API only — typical): public HTTPS URL of the FastAPI service, e.g.
#   VITE_API_URL=https://your-service-name.up.railway.app
# Same-origin / reverse-proxy setup (optional):
#   VITE_API_URL=https://yourdomain.com/api
VITE_API_URL=https://your-api.up.railway.app
