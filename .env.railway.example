# Example variables for Railway (API service). Copy names into the Railway dashboard;
# do not commit real secrets.

# Required: strong random secret for JWT signing
# JWT_SECRET=

# Required: exact browser origins for your static frontend (comma-separated, https, no trailing slash)
# CORS_ORIGINS=https://your-app.pages.dev

# SQLite on a Railway volume mounted at /data (omit DATABASE_URL for SQLite)
# SQLITE_DATABASE_PATH=/data/game.db

# Leave unset to use SQLite + SQLITE_DATABASE_PATH above
# DATABASE_URL=
